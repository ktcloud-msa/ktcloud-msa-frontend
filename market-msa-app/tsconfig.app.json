{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "esnext",
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@libs/*": [
        "./src/libs/*"
      ],
      "@providers/*": [
        "./src/providers/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@store/*": [
        "./src/store/*"
      ],
      "@typedef/*": [
        "./src/typedef/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
    }
  },
  "include": [
    "src"
  ],
}